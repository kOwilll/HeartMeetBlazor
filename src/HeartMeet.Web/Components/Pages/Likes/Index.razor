@page "/likes"
@attribute [Authorize]
@inject ILikeRepository LikeRepo
@inject IProfileRepository ProfileRepo
@inject AuthenticationStateProvider AuthState

<PageTitle>Кто вас лайкнул — HeartMeet</PageTitle>

<div style="min-height:100vh;background:#0d0a10;padding:2.5rem 2rem">
<div style="max-width:1100px;margin:0 auto">

    <div style="margin-bottom:2rem">
        <h1 style="font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:700;color:#f0e8f5;display:flex;align-items:center;gap:.75rem;margin-bottom:.4rem">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="#e87aaa"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Кто вас лайкнул
        </h1>
        <p style="color:#7a6080;font-size:1rem">@_likers.Count @Plural(_likers.Count) оценили вашу анкету</p>
    </div>

    @if (_loading)
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.25rem">
            @for (int i = 0; i < 8; i++) { <div class="skeleton" style="height:320px;border-radius:20px"></div> }
        </div>
    }
    else if (!_likers.Any())
    {
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6rem 2rem;text-align:center;gap:1.25rem">
            <div style="width:80px;height:80px;border-radius:50%;background:rgba(212,90,138,.1);border:1px solid rgba(212,90,138,.2);display:flex;align-items:center;justify-content:center">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#d45a8a" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:#c4a8d0">Пока никто не лайкнул</div>
            <p style="color:#7a6080;font-size:.95rem;max-width:380px;line-height:1.6">Заходите в ленту и знакомьтесь — кто-то обязательно ответит взаимностью!</p>
            <a href="/feed" style="display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 1.75rem;background:linear-gradient(135deg,#9e3a62,#e87aaa);border-radius:999px;color:#fff;text-decoration:none;font-size:.95rem;margin-top:.5rem">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                Перейти в ленту
            </a>
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.25rem">
            @foreach (var u in _likers)
            {
                var av = _avatars.GetValueOrDefault(u.Id);
                <a href="/profile/@u.Id" style="text-decoration:none;display:block;border-radius:20px;overflow:hidden;background:#1a1420;border:1px solid rgba(212,90,138,.1);transition:transform .2s,box-shadow .2s"
                   onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 20px 48px rgba(0,0,0,.5)'"
                   onmouseout="this.style.transform='';this.style.boxShadow=''">
                    <div style="aspect-ratio:3/4;position:relative;background:linear-gradient(135deg,#2a1535,#1a0d40)">
                        @if (av != null)
                        {
                            <img src="@av.Url" style="width:100%;height:100%;object-fit:cover" alt="@u.FirstName" />
                        }
                        else
                        {
                            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:5rem;color:rgba(255,255,255,.15)">@u.FirstName[0]</div>
                        }
                        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(13,10,16,.95) 0%,transparent 55%)"></div>

                        <!-- heart badge -->
                        <div style="position:absolute;top:.75rem;right:.75rem;width:36px;height:36px;border-radius:50%;background:rgba(212,90,138,.25);backdrop-filter:blur(8px);border:1px solid rgba(212,90,138,.4);display:flex;align-items:center;justify-content:center">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#e87aaa"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </div>

                        <div style="position:absolute;bottom:0;left:0;right:0;padding:1rem 1.1rem .9rem">
                            <div style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:#fff;display:flex;align-items:baseline;gap:.3rem">
                                @u.FirstName<span style="font-family:'Inter',sans-serif;font-size:1.1rem;font-weight:700;opacity:.75">, @u.Age</span>
                            </div>
                            @if (!string.IsNullOrEmpty(u.City))
                            {
                                <div style="display:flex;align-items:center;gap:.3rem;font-size:.82rem;color:rgba(255,255,255,.6);margin-top:.2rem">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    @u.City
                                </div>
                            }
                        </div>
                    </div>
                    <div style="padding:.85rem 1.1rem;display:flex;align-items:center;justify-content:space-between">
                        <span style="font-size:.82rem;color:#7a6080">Посмотреть профиль</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7a6080" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </div>
                </a>
            }
        </div>
    }
</div>
</div>

@code {
    List<ApplicationUser>  _likers  = new();
    Dictionary<string, Photo?> _avatars = new();
    bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var uid  = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        var ids  = await LikeRepo.GetLikerIdsAsync(uid);
        foreach (var id in ids)
        {
            var u = await ProfileRepo.GetByIdAsync(id);
            if (u != null && !u.IsBlocked) { _likers.Add(u); _avatars[id] = await ProfileRepo.GetAvatarAsync(id); }
        }
        _loading = false;
    }

    string Plural(int n) => n == 1 ? "человек" : n < 5 ? "человека" : "человек";
}
