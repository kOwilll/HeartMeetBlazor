@page "/profile/{UserId}"
@attribute [Authorize]
@inject IProfileRepository ProfileRepo
@inject ILikeService LikeService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Профиль — HeartMeet</PageTitle>

<div style="min-height:100vh;background:#0d0a10;display:flex;align-items:center;padding:3rem 2rem">
@if (_loading)
{
    <div style="max-width:1050px;margin:0 auto;width:100%;display:grid;grid-template-columns:380px 1fr;gap:2.5rem">
        <div class="skeleton" style="aspect-ratio:9/16;border-radius:24px"></div>
        <div style="display:flex;flex-direction:column;gap:1rem">
            <div class="skeleton" style="height:3rem;border-radius:12px;width:70%"></div>
            <div class="skeleton" style="height:1.5rem;border-radius:8px;width:40%"></div>
            <div class="skeleton" style="height:120px;border-radius:16px"></div>
        </div>
    </div>
}
else if (_user != null)
{
    <div style="max-width:1050px;margin:0 auto;width:100%">
        <div style="display:grid;grid-template-columns:380px 1fr;gap:2.5rem;align-items:start">

            <!-- Photos -->
            <div>
                <div style="aspect-ratio:9/16;border-radius:24px;overflow:hidden;background:#0a0810;position:relative;box-shadow:0 24px 60px rgba(0,0,0,.6)">
                    @if (_photos.Any())
                    {
                        <img id="mainPhoto" src="@_photos[_photoIdx].Url"
                             style="width:100%;height:100%;object-fit:contain;transition:opacity .25s" />
                    }
                    else
                    {
                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:9rem;color:rgba(255,255,255,.1)">
                            @_user.FirstName[0]
                        </div>
                    }
                    @if (_photos.Count > 1)
                    {
                        <!-- Progress bars -->
                        <div style="position:absolute;top:.65rem;left:.65rem;right:.65rem;display:flex;gap:.3rem;pointer-events:none">
                            @for (int i = 0; i < _photos.Count; i++)
                            {
                                <div style="@($"flex:1;height:3px;border-radius:2px;background:{(_photoIdx==i?"#fff":"rgba(255,255,255,.3)")};transition:background .2s")"></div>
                            }
                        </div>
                        <!-- Prev zone -->
                        <div @onclick="PrevPhoto"
                             style="position:absolute;left:0;top:1.5rem;bottom:0;width:40%;cursor:pointer;z-index:5">
                        </div>
                        <!-- Next zone -->
                        <div @onclick="NextPhoto"
                             style="position:absolute;right:0;top:1.5rem;bottom:0;width:60%;cursor:pointer;z-index:5">
                        </div>
                        <!-- Counter -->
                        <div style="position:absolute;bottom:.65rem;right:.65rem;background:rgba(0,0,0,.55);color:rgba(255,255,255,.8);font-size:.74rem;padding:.18rem .55rem;border-radius:999px;pointer-events:none">
                            @(_photoIdx+1)&nbsp;/&nbsp;@_photos.Count
                        </div>
                    }
                </div>
                @if (_photos.Count > 1)
                {
                    <div style="display:flex;gap:.4rem;margin-top:.65rem">
                        @for (int i = 0; i < _photos.Count; i++)
                        {
                            var ii = i;
                            <div @onclick="()=>{ _photoIdx=ii; }"
                                 style="@($"flex:1;aspect-ratio:1;border-radius:8px;overflow:hidden;cursor:pointer;border:2px solid {(_photoIdx==ii?"#d45a8a":"transparent")};opacity:{(_photoIdx==ii?"1":".5")};transition:all .2s")">
                                <img src="@_photos[ii].Url" style="width:100%;height:100%;object-fit:cover" />
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Info -->
            <div style="display:flex;flex-direction:column;gap:1.5rem">
                <div>
                    <h1 style="font-family:'Playfair Display',serif;font-size:3.2rem;font-weight:800;color:#f0e8f5;line-height:1.1;margin-bottom:.5rem">
                        @_user.FirstName<span style="font-size:2rem;font-weight:700;font-family:'Inter',sans-serif;opacity:.7">, @_user.Age</span>
                    </h1>
                    <div style="display:flex;flex-wrap:wrap;gap:.75rem;margin-top:.5rem">
                        @if (!string.IsNullOrEmpty(_user.City))
                        {
                            <span style="display:inline-flex;align-items:center;gap:.35rem;color:#9d6ed4;font-size:.95rem">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                @_user.City
                            </span>
                        }
                        <span style="display:inline-flex;align-items:center;gap:.35rem;color:#4a3855;font-size:.9rem">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            С нами с @_user.CreatedAt.ToString("MMM yyyy")
                        </span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_user.Bio))
                {
                    <div style="background:#1a1420;border:1px solid rgba(212,90,138,.12);border-radius:18px;padding:1.25rem 1.5rem">
                        <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;margin-bottom:.6rem;font-weight:700">О себе</div>
                        <p style="color:#c4a8d0;line-height:1.8;font-size:1rem">@_user.Bio</p>
                    </div>
                }

                @if (_interests.Any())
                {
                    <div style="background:#1a1420;border:1px solid rgba(212,90,138,.12);border-radius:18px;padding:1.25rem 1.5rem">
                        <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;margin-bottom:.75rem;font-weight:700">Интересы</div>
                        <div style="display:flex;flex-wrap:wrap;gap:.45rem">
                            @foreach (var i in _interests)
                            {
                                <span style="display:inline-flex;align-items:center;gap:.3rem;padding:.35rem .85rem;border-radius:999px;background:rgba(212,90,138,.1);border:1px solid rgba(212,90,138,.22);color:#e87aaa;font-size:.88rem">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                    @i.Name
                                </span>
                            }
                        </div>
                    </div>
                }

                <!-- Actions -->
                <div style="display:flex;flex-direction:column;gap:.75rem">
                    @if (UserId == _myId)
                    {
                        <a href="/profile/edit"
                           style="display:flex;align-items:center;justify-content:center;gap:.6rem;padding:1rem;background:linear-gradient(135deg,#9e3a62,#e87aaa);border-radius:14px;color:#fff;font-size:1rem;font-weight:600;text-decoration:none">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Редактировать анкету
                        </a>
                        <a href="/chats"
                           style="display:flex;align-items:center;justify-content:center;gap:.6rem;padding:.9rem;background:transparent;border:1px solid rgba(212,90,138,.3);border-radius:14px;color:#e87aaa;font-size:1rem;text-decoration:none">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            Мои чаты
                        </a>
                    }
                    else
                    {
                        <!-- Like button — pure JS, no Blazor event -->
                        <button id="likeBtn"
                                onclick="toggleLike('@UserId', '@_myId', this)"
                                style="@($"display:flex;align-items:center;justify-content:center;gap:.6rem;padding:1rem;border:none;border-radius:14px;font-size:1rem;font-weight:600;cursor:pointer;width:100%;transition:all .2s;{(_liked?"background:linear-gradient(135deg,#9e3a62,#e87aaa);color:#fff":"background:transparent;border:1px solid rgba(212,90,138,.35);color:#e87aaa")}")"
                                data-liked="@(_liked ? "1" : "0")">
                            <svg id="likeSvg" width="18" height="18" viewBox="0 0 24 24" fill="@(_liked ? "currentColor" : "none")" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                            <span id="likeTxt">@(_liked ? "Нравится" : "Поставить лайк")</span>
                        </button>
                        <a href="/feed"
                           style="display:flex;align-items:center;justify-content:center;gap:.6rem;padding:.9rem;background:transparent;border:1px solid rgba(255,255,255,.08);border-radius:14px;color:#7a6080;font-size:.95rem;text-decoration:none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                            Назад к анкетам
                        </a>
                    }
                </div>

                @if (_showMatch)
                {
                    <div style="background:linear-gradient(135deg,rgba(158,58,98,.15),rgba(124,77,186,.15));border:1px solid rgba(212,90,138,.3);border-radius:18px;padding:1.5rem;text-align:center">
                        <div style="font-size:2rem;margin-bottom:.5rem">💕</div>
                        <div style="font-family:'Playfair Display',serif;font-size:1.4rem;color:#e87aaa;margin-bottom:.5rem">Взаимная симпатия!</div>
                        <p style="color:#c4a8d0;font-size:.9rem;margin-bottom:1rem">Вы и @_user.FirstName понравились друг другу!</p>
                        <a href="/chats" style="display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.5rem;background:linear-gradient(135deg,#9e3a62,#e87aaa);border-radius:999px;color:#fff;text-decoration:none;font-size:.9rem">
                            💬 Написать сообщение
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}
</div>

<script>
function toggleLike(targetId, myId, btn) {
    var isLiked = btn.getAttribute('data-liked') === '1';
    var url = isLiked ? '/api/profile/unlike/' + targetId : '/api/profile/like/' + targetId;
    btn.disabled = true;
    btn.style.opacity = '0.6';

    fetch(url, { method: 'POST', credentials: 'include' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false; btn.style.opacity = '1';
        var nowLiked = data.liked !== false && !isLiked || data.liked === true;
        // Toggle liked state
        if (isLiked) {
            // Just unliked
            btn.setAttribute('data-liked', '0');
            btn.style.background = 'transparent';
            btn.style.border = '1px solid rgba(212,90,138,.35)';
            btn.style.color = '#e87aaa';
            document.getElementById('likeSvg').setAttribute('fill', 'none');
            document.getElementById('likeTxt').textContent = 'Поставить лайк';
        } else {
            // Just liked
            btn.setAttribute('data-liked', '1');
            btn.style.background = 'linear-gradient(135deg,#9e3a62,#e87aaa)';
            btn.style.border = 'none';
            btn.style.color = '#fff';
            document.getElementById('likeSvg').setAttribute('fill', 'currentColor');
            document.getElementById('likeTxt').textContent = 'Нравится';
            // Show match inline if match
            if (data.isMatch) {
                var matchDiv = document.createElement('div');
                matchDiv.innerHTML = '<div style="background:linear-gradient(135deg,rgba(158,58,98,.15),rgba(124,77,186,.15));border:1px solid rgba(212,90,138,.3);border-radius:18px;padding:1.5rem;text-align:center;margin-top:.75rem"><div style="font-size:2rem">💕</div><div style="font-family:Playfair Display,serif;font-size:1.4rem;color:#e87aaa;margin:.5rem 0">Взаимная симпатия!</div><a href="/chats" style="display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.5rem;background:linear-gradient(135deg,#9e3a62,#e87aaa);border-radius:999px;color:#fff;text-decoration:none">💬 Написать</a></div>';
                btn.parentNode.appendChild(matchDiv);
            }
        }
    })
    .catch(function() { btn.disabled = false; btn.style.opacity = '1'; });
}
</script>

@code {
    [Parameter] public string UserId { get; set; } = "";
    ApplicationUser? _user;
    string _myId = "";
    List<Photo>    _photos    = new();
    List<Interest> _interests = new();
    bool _loading = true, _liked, _showMatch;
    int  _photoIdx;

    protected override async Task OnInitializedAsync()
    {
        var auth   = await AuthState.GetAuthenticationStateAsync();
        _myId      = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _user      = await ProfileRepo.GetByIdAsync(UserId);
        _photos    = await ProfileRepo.GetPhotosAsync(UserId);
        _liked     = await LikeService.HasLikedAsync(_myId, UserId);
        var ids    = await ProfileRepo.GetUserInterestIdsAsync(UserId);
        var all    = await ProfileRepo.GetInterestsAsync();
        _interests = all.Where(i => ids.Contains(i.Id)).ToList();
        _loading   = false;
    }

    void PrevPhoto() { if (_photos.Count > 1) _photoIdx = (_photoIdx - 1 + _photos.Count) % _photos.Count; }
    void NextPhoto() { if (_photos.Count > 1) _photoIdx = (_photoIdx + 1) % _photos.Count; }
}
