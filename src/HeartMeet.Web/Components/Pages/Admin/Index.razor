@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IAdminRepository AdminRepo
@inject AuthenticationStateProvider AuthState

<PageTitle>Админ-панель — HeartMeet</PageTitle>

<div style="min-height:100vh;background:#0d0a10;padding:2rem 1.25rem">
<div style="max-width:100%;margin:0 auto">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem">
        <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;color:#f0e8f5;display:flex;align-items:center;gap:.75rem">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#e87aaa" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Панель управления
        </h1>
        <div style="display:flex;align-items:center;gap:.75rem">
            <div style="background:#1a1420;border:1px solid rgba(212,90,138,.15);border-radius:12px;padding:.5rem 1rem;font-size:.88rem;color:#7a6080">
                Всего пользователей: <strong style="color:#f0e8f5">@_users.Count</strong>
            </div>
            <div style="background:#1a1420;border:1px solid rgba(224,90,106,.2);border-radius:12px;padding:.5rem 1rem;font-size:.88rem;color:#7a6080">
                Заблокированных: <strong style="color:#e05a6a">@_users.Count(u => u.IsBlocked)</strong>
            </div>
        </div>
    </div>

    <div style="background:#1a1420;border:1px solid rgba(212,90,138,.1);border-radius:20px;overflow:hidden">
        <div style="overflow-x:auto">
            <table style="width:100%;border-collapse:collapse">
                <thead>
                    <tr style="border-bottom:1px solid rgba(212,90,138,.1)">
                        <th style="padding:.85rem 1rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700;white-space:nowrap">Пользователь</th>
                        <th style="padding:.85rem 1rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700">Email</th>
                        <th style="padding:.85rem 1rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700;white-space:nowrap">Возраст / Город</th>
                        <th style="padding:.85rem 1rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700;white-space:nowrap">Регистрация</th>
                        <th style="padding:.85rem 1rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700">Статус</th>
                        <th style="padding:1rem 1rem;text-align:right;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700;white-space:nowrap">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in _users)
                    {
                        var uid     = u.Id;
                        var blocked = u.IsBlocked;
                        var rowId   = "row-" + uid[..8];
                        <tr id="@rowId" style="border-bottom:1px solid rgba(255,255,255,.03);transition:background .15s" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="this.style.background='transparent'">
                            <td style="padding:.8rem 1rem">
                                <div style="display:flex;align-items:center;gap:.75rem">
                                    <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#9e3a62,#7c4dba);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:#fff;flex-shrink:0">
                                        @(u.FirstName.FirstOrDefault())
                                    </div>
                                    <div>
                                        <div style="font-weight:600;color:#f0e8f5;font-size:.95rem">@u.FirstName</div>
                                        <div style="font-size:.75rem;color:#4a3855">ID: @uid[..8]…</div>
                                    </div>
                                </div>
                            </td>
                            <td style="padding:.8rem 1rem;color:#7a6080;font-size:.88rem">@u.Email</td>
                            <td style="padding:.8rem 1rem;color:#7a6080;font-size:.88rem;white-space:nowrap">@u.Age лет @(!string.IsNullOrEmpty(u.City) ? "· " + u.City : "")</td>
                            <td style="padding:.8rem 1rem;color:#7a6080;font-size:.88rem;white-space:nowrap">@u.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</td>
                            <td style="padding:.8rem 1rem" class="status-cell">
                                @if (blocked)
                                {
                                    <span style="display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:999px;font-size:.75rem;font-weight:600;background:rgba(224,90,106,.12);color:#e05a6a;border:1px solid rgba(224,90,106,.25)">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                        Заблокирован
                                    </span>
                                }
                                else
                                {
                                    <span style="display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:999px;font-size:.75rem;font-weight:600;background:rgba(76,175,130,.1);color:#4caf82;border:1px solid rgba(76,175,130,.22)">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                        Активен
                                    </span>
                                }
                            </td>
                            <td style="padding:.8rem 1rem;text-align:right">
                                @if (uid == _myId)
                                {
                                    <span style="display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .85rem;border-radius:999px;font-size:.78rem;font-weight:600;background:rgba(124,77,186,.12);color:#9d6ed4;border:1px solid rgba(124,77,186,.25)">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        Это вы
                                    </span>
                                }
                                else
                                {
                                <div style="display:flex;align-items:center;justify-content:flex-end;gap:.5rem">
                                    <a href="/profile/@uid" target="_blank"
                                       style="display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .65rem;background:transparent;border:1px solid rgba(255,255,255,.08);border-radius:8px;color:#7a6080;font-size:.76rem;text-decoration:none;transition:border-color .15s,color .15s"
                                       onmouseover="this.style.borderColor='rgba(212,90,138,.3)';this.style.color='#e87aaa'"
                                       onmouseout="this.style.borderColor='rgba(255,255,255,.08)';this.style.color='#7a6080'">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        Профиль
                                    </a>
                                    @if (blocked)
                                    {
                                        <button onclick="adminAction('unblock','@uid','@rowId')"
                                                class="action-unblock"
                                                style="display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .65rem;background:rgba(76,175,130,.1);border:1px solid rgba(76,175,130,.25);border-radius:8px;color:#4caf82;font-size:.76rem;cursor:pointer;transition:all .15s"
                                                onmouseover="this.style.background='rgba(76,175,130,.2)'" onmouseout="this.style.background='rgba(76,175,130,.1)'">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
                                            Разблокировать
                                        </button>
                                    }
                                    else
                                    {
                                        <button onclick="adminAction('block','@uid','@rowId')"
                                                class="action-block"
                                                style="display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .65rem;background:rgba(212,90,138,.1);border:1px solid rgba(212,90,138,.25);border-radius:8px;color:#e87aaa;font-size:.76rem;cursor:pointer;transition:all .15s"
                                                onmouseover="this.style.background='rgba(212,90,138,.2)'" onmouseout="this.style.background='rgba(212,90,138,.1)'">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                            Заблокировать
                                        </button>
                                    }
                                    <button onclick="adminAction('delete','@uid','@rowId')"
                                            style="display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .65rem;background:rgba(224,90,106,.1);border:1px solid rgba(224,90,106,.25);border-radius:8px;color:#e05a6a;font-size:.76rem;cursor:pointer;transition:all .15s"
                                            onmouseover="this.style.background='rgba(224,90,106,.2)'" onmouseout="this.style.background='rgba(224,90,106,.1)'">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                        Удалить
                                    </button>
                                </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

<script>
function adminAction(action, userId, rowId) {
    if (action === 'delete' && !confirm('Удалить этого пользователя? Это действие необратимо.')) return;

    var url    = action === 'delete' ? '/api/admin/user/' + userId : '/api/admin/' + action + '/' + userId;
    var method = action === 'delete' ? 'DELETE' : 'POST';

    fetch(url, { method: method, credentials: 'include' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.error) { alert(data.error); return; }
        if (!data.success) { alert('Ошибка операции'); return; }

        if (action === 'delete') {
            var row = document.getElementById(rowId);
            if (row) {
                row.style.transition = 'opacity .3s';
                row.style.opacity = '0';
                setTimeout(function(){ row.remove(); }, 320);
            }
        } else if (action === 'block') {
            // Update status badge
            var badge = document.querySelector('#' + rowId + ' .status-cell');
            if (badge) badge.innerHTML = '<span style="display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:999px;font-size:.75rem;font-weight:600;background:rgba(224,90,106,.12);color:#e05a6a;border:1px solid rgba(224,90,106,.25)"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>Заблокирован</span>';
            // Swap block button → unblock button
            var btn = document.querySelector('#' + rowId + ' .action-block');
            if (btn) {
                btn.className = btn.className.replace('action-block', 'action-unblock');
                btn.style.background = 'rgba(76,175,130,.1)';
                btn.style.borderColor = 'rgba(76,175,130,.25)';
                btn.style.color = '#4caf82';
                btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg> Разблокировать';
                btn.setAttribute('onclick', "adminAction('unblock','" + userId + "','" + rowId + "')");
                btn.onmouseover = function(){ this.style.background='rgba(76,175,130,.2)'; };
                btn.onmouseout  = function(){ this.style.background='rgba(76,175,130,.1)'; };
            }
        } else if (action === 'unblock') {
            // Update status badge
            var badge = document.querySelector('#' + rowId + ' .status-cell');
            if (badge) badge.innerHTML = '<span style="display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:999px;font-size:.75rem;font-weight:600;background:rgba(76,175,130,.1);color:#4caf82;border:1px solid rgba(76,175,130,.22)"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Активен</span>';
            // Swap unblock button → block button
            var btn = document.querySelector('#' + rowId + ' .action-unblock');
            if (btn) {
                btn.className = btn.className.replace('action-unblock', 'action-block');
                btn.style.background = 'rgba(212,90,138,.1)';
                btn.style.borderColor = 'rgba(212,90,138,.25)';
                btn.style.color = '#e87aaa';
                btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Заблокировать';
                btn.setAttribute('onclick', "adminAction('block','" + userId + "','" + rowId + "')");
                btn.onmouseover = function(){ this.style.background='rgba(212,90,138,.2)'; };
                btn.onmouseout  = function(){ this.style.background='rgba(212,90,138,.1)'; };
            }
        }
    })
    .catch(function(e) { alert('Ошибка: ' + e.message); });
}
</script>

@code {
    List<ApplicationUser> _users = new();
    string _myId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _myId    = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _users   = await AdminRepo.GetAllUsersAsync();
    }
}
