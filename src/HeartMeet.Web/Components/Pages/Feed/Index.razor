@page "/"
@page "/feed"
@attribute [Authorize]

<PageTitle>Анкеты — HeartMeet</PageTitle>
<AntiforgeryToken />

<!-- Pure JS feed — no Blazor rendering after load -->
<div id="feedRoot" style="position:fixed;top:0;right:0;bottom:0;left:280px;background:#0d0a10;display:flex;flex-direction:column;align-items:center;font-family:Inter,sans-serif">
    <div id="feedBody" style="flex:1;display:flex;flex-direction:column;align-items:center;width:100%;min-height:0">
        <div style="color:#7a6080;margin-top:4rem;font-size:1rem" id="loadMsg">Загружаем анкеты...</div>
    </div>
</div>

<script>
(function(){
    var queue = [], idx = 0, busy = false;

    // Load queue from API
    fetch('/api/feed/queue', {credentials:'include'})
        .then(function(r){
            if(!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function(data){
            queue = Array.isArray(data) ? data : [];
            showCard();
        })
        .catch(function(e){
            var el = document.getElementById('loadMsg');
            if(el) el.textContent = 'Ошибка загрузки (' + e.message + ')';
        });

    function showCard(){
        var body = document.getElementById('feedBody');
        if(!body) return;
        if(idx >= queue.length){
            body.innerHTML = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:1.25rem;text-align:center;padding:2rem">'
                + '<div style="width:80px;height:80px;border-radius:50%;background:rgba(212,90,138,.1);border:1px solid rgba(212,90,138,.2);display:flex;align-items:center;justify-content:center">'
                +   '<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#d45a8a" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/><line x1="4" y1="4" x2="20" y2="20" stroke="#e05a6a" stroke-width="1.5"/></svg>'
                + '</div>'
                + '<div style="font-family:\'Playfair Display\',serif;font-size:2rem;font-weight:700;color:#c4a8d0">Анкеты закончились</div>'
                + '<p style="color:#7a6080;font-size:.95rem;max-width:280px;line-height:1.6">Вы просмотрели всех. Зайдите позже или сбросьте список.</p>'
                + '<button onclick="reloadFeed()" style="display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.6rem;background:linear-gradient(135deg,#9e3a62,#e87aaa);border:none;border-radius:999px;color:#fff;cursor:pointer;font-size:.95rem;font-family:Inter,sans-serif">'
                +   '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>'
                +   'Обновить анкеты'
                + '</button>'
                + '</div>';
            return;
        }
        var u = queue[idx];
        var photoSrc = u.photos && u.photos.length > 0 ? u.photos[0] : null;
        var photoIdx = 0;

        var tagsHtml = '';
        if(u.interests && u.interests.length > 0){
            u.interests.slice(0,4).forEach(function(t){
                tagsHtml += '<span style="font-size:.82rem;padding:.25rem .7rem;border-radius:999px;background:rgba(212,90,138,.22);border:1px solid rgba(212,90,138,.38);color:#f0c0d8">'+t+'</span>';
            });
        }

        var dotsHtml = '';
        if(u.photos && u.photos.length > 1){
            u.photos.forEach(function(_,i){
                dotsHtml += '<div id="dot'+i+'" style="flex:1;height:3px;border-radius:2px;background:'+(i===0?'rgba(255,255,255,.9)':'rgba(255,255,255,.35)')+'"></div>';
            });
        }

        body.innerHTML =
          '<div style="width:100%;max-width:480px;text-align:right;padding:.3rem 1rem;flex-shrink:0">'
          + '<span style="font-size:.72rem;color:#4a3855">'+(queue.length-idx)+' осталось</span></div>'
          + '<div style="flex:1;width:100%;max-width:480px;padding:0 1rem;min-height:0;display:flex;flex-direction:column">'
          +   '<div id="hmCard" style="flex:1;border-radius:24px;overflow:hidden;position:relative;background:linear-gradient(135deg,#2a1535,#1a0d40);cursor:grab;box-shadow:0 20px 60px rgba(0,0,0,.6)">'
          +     (photoSrc ? '<img id="cardImg" src="'+photoSrc+'" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover">' : '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:\'Playfair Display\',serif;font-size:9rem;color:rgba(255,255,255,.1)">'+u.name[0]+'</div>')
          +     '<div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(13,10,16,.97) 0%,rgba(13,10,16,.3) 45%,transparent 70%)"></div>'
          +     '<div id="stampLike" style="position:absolute;top:1.75rem;left:1.25rem;font-family:\'Playfair Display\',serif;font-size:2rem;font-weight:700;color:#4caf82;border:4px solid #4caf82;padding:.2rem .8rem;border-radius:10px;transform:rotate(-12deg);opacity:0;transition:opacity .12s;pointer-events:none">LIKE ♥</div>'
          +     '<div id="stampNope" style="position:absolute;top:1.75rem;right:1.25rem;font-family:\'Playfair Display\',serif;font-size:2rem;font-weight:700;color:#e05a6a;border:4px solid #e05a6a;padding:.2rem .8rem;border-radius:10px;transform:rotate(12deg);opacity:0;transition:opacity .12s;pointer-events:none">NOPE ✕</div>'
          +     (dotsHtml ? '<div id="dots" style="position:absolute;top:.6rem;left:.6rem;right:.6rem;display:flex;gap:.3rem">'+dotsHtml+'</div>' : '')
          +     '<div style="position:absolute;bottom:0;left:0;right:0;padding:1.5rem 1.5rem 1rem">'
          +       '<div style="font-family:\'Playfair Display\',serif;font-size:2.6rem;font-weight:700;color:#fff;display:flex;align-items:baseline;gap:.5rem;margin-bottom:.2rem">'+u.name+' <span style="font-size:1.5rem;opacity:.85;font-weight:700;font-family:Inter,sans-serif">'+u.age+'</span></div>'
          +       (u.city ? '<div style="color:rgba(255,255,255,.7);font-size:1rem;margin-bottom:.4rem">📍 '+u.city+'</div>' : '')
          +       (u.bio  ? '<p style="color:rgba(255,255,255,.8);font-size:.95rem;line-height:1.6;margin-bottom:.55rem">'+(u.bio.length>80?u.bio.substring(0,80)+'…':u.bio)+'</p>' : '')
          +       (tagsHtml ? '<div style="display:flex;flex-wrap:wrap;gap:.25rem">'+tagsHtml+'</div>' : '')
          +     '</div>'
          +     (u.photos && u.photos.length > 1
                  ? '<div onclick="prevPhoto()" style="position:absolute;left:0;top:3rem;bottom:38%;width:35%;cursor:pointer;z-index:5"></div>'
                  + '<div onclick="nextPhoto()" style="position:absolute;right:0;top:3rem;bottom:38%;width:65%;cursor:pointer;z-index:5"></div>'
                  : '')
          +   '</div>'
          + '</div>'
          + '<div style="display:flex;align-items:center;justify-content:center;gap:1.1rem;padding:.75rem 0 1rem;flex-shrink:0">'
          +   '<button onclick="doNope()" style="width:58px;height:58px;border-radius:50%;background:white;border:none;color:#e05a6a;font-size:1.3rem;cursor:pointer;box-shadow:0 4px 20px rgba(224,90,106,.3)">✕</button>'
          +   '<a href="/profile/'+u.id+'" style="width:44px;height:44px;border-radius:50%;background:#211829;border:1px solid rgba(220,100,160,.15);display:flex;align-items:center;justify-content:center;color:#7a6080;font-size:1rem;text-decoration:none">ℹ</a>'
          +   '<button onclick="doLike()" style="width:68px;height:68px;border-radius:50%;background:linear-gradient(135deg,#9e3a62,#e87aaa);border:none;color:white;font-size:1.6rem;cursor:pointer;box-shadow:0 6px 24px rgba(212,90,138,.5)">♥</button>'
          + '</div>';

        initDrag();

        function prevPhoto(){
            if(!u.photos||u.photos.length<2) return;
            photoIdx=(photoIdx-1+u.photos.length)%u.photos.length;
            updatePhoto();
        }
        function nextPhoto(){
            if(!u.photos||u.photos.length<2) return;
            photoIdx=(photoIdx+1)%u.photos.length;
            updatePhoto();
        }
        function updatePhoto(){
            var img=document.getElementById('cardImg');
            if(img) img.src=u.photos[photoIdx];
            u.photos.forEach(function(_,i){
                var d=document.getElementById('dot'+i);
                if(d) d.style.background=i===photoIdx?'rgba(255,255,255,.9)':'rgba(255,255,255,.35)';
            });
        }
        window.prevPhoto=prevPhoto;
        window.nextPhoto=nextPhoto;
    }

    function fly(dir, cb){
        var card=document.getElementById('hmCard');
        if(!card){ cb&&cb(); return; }
        var sl=document.getElementById('stampLike'), sn=document.getElementById('stampNope');
        if(dir==='right'&&sl) sl.style.opacity='1';
        if(dir==='left' &&sn) sn.style.opacity='1';
        card.style.transition='transform .38s ease, opacity .38s ease';
        card.style.transform='translateX('+(dir==='right'?'160%':'-160%')+') rotate('+(dir==='right'?'30':'-30')+'deg)';
        card.style.opacity='0';
        card.style.pointerEvents='none';
        setTimeout(cb, 400);
    }

    function showMatch(name){
        var body=document.getElementById('feedBody');
        if(!body) return;
        body.innerHTML='<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:1rem;text-align:center;padding:2rem">'
            +'<div style="font-size:4rem">💕</div>'
            +'<div style="font-family:\'Playfair Display\',serif;font-size:2.5rem;font-style:italic;color:#e87aaa">Взаимная симпатия!</div>'
            +'<p style="color:#c4a8d0">Вы и <strong style="color:#f0e8f5">'+name+'</strong> понравились друг другу!</p>'
            +'<div style="display:flex;gap:1rem;margin-top:1rem">'
            +'<button onclick="window.location.href=\'/chats\'" style="padding:.75rem 1.75rem;background:linear-gradient(135deg,#9e3a62,#e87aaa);border:none;border-radius:999px;color:#fff;font-size:1rem;cursor:pointer">💬 Написать</button>'
            +'<button onclick="idx++;showCard()" style="padding:.75rem 1.75rem;background:transparent;border:1px solid rgba(220,100,160,.3);border-radius:999px;color:#7a6080;font-size:1rem;cursor:pointer">Продолжить</button>'
            +'</div></div>';
    }

    window.doLike = function(){
        if(busy||idx>=queue.length) return;
        busy=true;
        var u=queue[idx];
        fly('right', function(){
            fetch('/api/feed/like/'+u.id, {method:'POST', credentials:'include'})
                .then(function(r){ return r.json(); })
                .then(function(data){
                    idx++;
                    busy=false;
                    if(data.isMatch) showMatch(u.name);
                    else showCard();
                })
                .catch(function(){ idx++; busy=false; showCard(); });
        });
    };

    window.doNope = function(){
        if(busy||idx>=queue.length) return;
        busy=true;
        fly('left', function(){ idx++; busy=false; showCard(); });
    };

    function getAntiForgery(){
        var el=document.querySelector('input[name=__RequestVerificationToken]');
        return el ? el.value : '';
    }

    function initDrag(){
        var card=document.getElementById('hmCard');
        if(!card) return;
        var sx=0, drag=false;
        function start(x){ sx=x; drag=true; card.style.transition='none'; card.style.cursor='grabbing'; }
        function move(x){
            if(!drag) return;
            var dx=x-sx;
            card.style.transform='translateX('+dx+'px) rotate('+(dx*.05)+'deg)';
            var sl=document.getElementById('stampLike'), sn=document.getElementById('stampNope');
            if(sl) sl.style.opacity=dx>55?'1':'0';
            if(sn) sn.style.opacity=dx<-55?'1':'0';
        }
        function end(x){
            if(!drag) return; drag=false; card.style.cursor='grab';
            var dx=x-sx;
            if(dx>90) window.doLike();
            else if(dx<-90) window.doNope();
            else{ card.style.transition='transform .28s ease'; card.style.transform=''; }
        }
        card.addEventListener('mousedown', function(e){ start(e.clientX); e.preventDefault(); });
        window.addEventListener('mousemove', function(e){ move(e.clientX); });
        window.addEventListener('mouseup',   function(e){ end(e.clientX); });
        card.addEventListener('touchstart', function(e){ start(e.touches[0].clientX); }, {passive:true});
        card.addEventListener('touchmove',  function(e){ move(e.touches[0].clientX); },  {passive:true});
        card.addEventListener('touchend',   function(e){ end(e.changedTouches[0].clientX); }, {passive:true});
    }

    window.reloadFeed = function(){
        idx = 0; busy = false;
        var body = document.getElementById('feedBody');
        if(body) body.innerHTML = '<div style="color:#7a6080;margin-top:4rem;font-size:1rem">Загружаем анкеты...</div>';
        fetch('/api/feed/queue', {credentials:'include'})
            .then(function(r){ if(!r.ok) throw new Error('HTTP '+r.status); return r.json(); })
            .then(function(data){ queue = Array.isArray(data) ? data : []; showCard(); })
            .catch(function(e){ if(body) body.innerHTML = '<div style="color:#e05a6a;padding:2rem">Ошибка: ' + e.message + '</div>'; });
    };
})();
</script>
