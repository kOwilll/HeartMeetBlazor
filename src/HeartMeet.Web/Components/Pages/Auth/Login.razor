@page "/auth/login"
@layout HeartMeet.Web.Components.Layout.AuthLayout

<PageTitle>HeartMeet — Войти</PageTitle>

<div class="auth-split">
    <div class="auth-visual">
        <div class="auth-visual__bg"></div>
        <div class="auth-visual__content">
            <div class="auth-visual__logo">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <span>HeartMeet</span>
            </div>
            <h2 class="auth-visual__title">Найди того,<br/>кто тебя ждёт</h2>
            <p class="auth-visual__sub">Тысячи людей уже нашли свою половинку. Твоя история начинается здесь.</p>
        </div>
        <div class="auth-visual__orbs">
            <div class="auth-orb auth-orb--1"></div>
            <div class="auth-orb auth-orb--2"></div>
            <div class="auth-orb auth-orb--3"></div>
        </div>
    </div>

    <div class="auth-form-side">
        <div class="auth-form-wrap">
            <div class="auth-form-header">
                <h1 class="auth-form-title">С возвращением</h1>
                <p class="auth-form-sub">Рады снова видеть вас</p>
            </div>

            @if (Error == "invalid")
            {
                <div class="auth-alert">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Неверный email или пароль
                </div>
            }
            @if (Error == "blocked")
            {
                <div style="background:rgba(224,90,106,.08);border:1px solid rgba(224,90,106,.3);border-radius:16px;padding:1.25rem 1.5rem;margin-bottom:1.5rem">
                    <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e05a6a" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                        <span style="font-weight:700;color:#e05a6a">Аккаунт заблокирован</span>
                    </div>
                    <p style="color:rgba(224,90,106,.8);font-size:.88rem;line-height:1.6;margin:0">
                        Ваш аккаунт заблокирован за нарушение правил нашего сайта.<br/>
                        Если вы считаете это ошибкой, обратитесь в поддержку.
                    </p>
                </div>
            }

            <form action="/account/login" method="post" class="auth-form">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                <div class="auth-field">
                    <label class="auth-label">Email</label>
                    <div class="auth-input-wrap">
                        <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <input class="auth-input" type="email" name="email" placeholder="you@example.com" required autocomplete="email" />
                    </div>
                </div>
                <div class="auth-field">
                    <label class="auth-label">Пароль</label>
                    <div class="auth-input-wrap">
                        <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        <input class="auth-input" type="password" name="password" placeholder="••••••••" required autocomplete="current-password" />
                    </div>
                </div>
                <button type="submit" class="auth-btn">
                    Войти
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </form>

            <div class="auth-divider"><span>или</span></div>

            <div class="auth-switch">
                Нет аккаунта?
                <a href="/auth/register" class="auth-switch__link">Зарегистрироваться</a>
            </div>

            <div class="auth-hints">
                <div class="auth-hints__title">Тест-аккаунты — нажмите чтобы войти</div>
                <div class="auth-hint" onclick="document.querySelector('[name=email]').value='anna@test.ru';document.querySelector('[name=password]').value='Test123!'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Анна, 25 · anna@test.ru
                </div>
                <div class="auth-hint" onclick="document.querySelector('[name=email]').value='kate@test.ru';document.querySelector('[name=password]').value='Test123!'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Катя, 23 · kate@test.ru
                </div>
                <div class="auth-hint" onclick="document.querySelector('[name=email]').value='alex@test.ru';document.querySelector('[name=password]').value='Test123!'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Алексей, 28 · alex@test.ru
                </div>
                <div class="auth-hint" onclick="document.querySelector('[name=email]').value='masha@test.ru';document.querySelector('[name=password]').value='Test123!'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Маша, 26 · masha@test.ru
                </div>
                <div class="auth-hint" onclick="document.querySelector('[name=email]').value='dmitry@test.ru';document.querySelector('[name=password]').value='Test123!'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Дмитрий, 31 · dmitry@test.ru
                </div>
                <div class="auth-hint" onclick="document.querySelector('[name=email]').value='admin@heartmeet.ru';document.querySelector('[name=password]').value='Admin123!'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Администратор · admin@heartmeet.ru
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] string? Error { get; set; }
    [SupplyParameterFromQuery] string? ReturnUrl { get; set; }
}
