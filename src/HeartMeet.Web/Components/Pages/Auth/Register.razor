@page "/auth/register"
@layout HeartMeet.Web.Components.Layout.AuthLayout

<PageTitle>HeartMeet — Регистрация</PageTitle>

<div class="auth-split">
    <div class="auth-visual">
        <div class="auth-visual__bg"></div>
        <div class="auth-visual__content">
            <div class="auth-visual__logo">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <span>HeartMeet</span>
            </div>
            <h2 class="auth-visual__title">Начни свою<br/>историю любви</h2>
            <p class="auth-visual__sub">Создай анкету за 30 секунд и начни знакомиться прямо сейчас.</p>
        </div>
        <div class="auth-visual__orbs">
            <div class="auth-orb auth-orb--1"></div>
            <div class="auth-orb auth-orb--2"></div>
            <div class="auth-orb auth-orb--3"></div>
        </div>
    </div>

    <div class="auth-form-side">
        <div class="auth-form-wrap">
            <div class="auth-form-header">
                <h1 class="auth-form-title">Создать аккаунт</h1>
                <p class="auth-form-sub">Это займёт меньше минуты</p>
            </div>

            @if (!string.IsNullOrEmpty(Error))
            {
                <div class="auth-alert">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @Error
                </div>
            }

            <form action="/account/register" method="post" class="auth-form">
                <AntiforgeryToken />
                <div class="auth-row">
                    <div class="auth-field">
                        <label class="auth-label">Имя</label>
                        <div class="auth-input-wrap">
                            <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <input class="auth-input" type="text" name="firstName" placeholder="Алексей" required />
                        </div>
                    </div>
                    <div class="auth-field">
                        <label class="auth-label">Возраст</label>
                        <div class="auth-input-wrap">
                            <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            <input class="auth-input" type="number" name="age" min="18" max="80" placeholder="25" required />
                        </div>
                    </div>
                </div>
                <div class="auth-field">
                    <label class="auth-label">Город</label>
                    <div class="auth-input-wrap">
                        <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        <input class="auth-input" type="text" name="city" placeholder="Москва" />
                    </div>
                </div>
                <div class="auth-field">
                    <label class="auth-label">Email</label>
                    <div class="auth-input-wrap">
                        <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <input class="auth-input" type="email" name="email" placeholder="you@example.com" required autocomplete="email" />
                    </div>
                </div>
                <div class="auth-field">
                    <label class="auth-label">Пароль</label>
                    <div class="auth-input-wrap">
                        <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        <input class="auth-input" type="password" name="password" placeholder="минимум 6 символов" required minlength="6" autocomplete="new-password" />
                    </div>
                </div>
                <button type="submit" class="auth-btn">
                    Создать аккаунт
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </form>

            <div class="auth-switch">
                Уже есть аккаунт?
                <a href="/auth/login" class="auth-switch__link">Войти</a>
            </div>
        </div>
    </div>
</div>

@code { [SupplyParameterFromQuery] string? Error { get; set; } }
