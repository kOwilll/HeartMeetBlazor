@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject INotificationRepository NotifRepo
@inject INotificationService NotifSvc
@inject IChatRepository ChatRepo
@inject IProfileRepository ProfileRepo
@implements IDisposable

<div id="sidebar" style="position:fixed;top:0;left:0;bottom:0;width:280px;background:#0e0b12;border-right:1px solid rgba(212,90,138,.12);display:flex;flex-direction:column;z-index:100">

    <!-- Logo -->
    <div style="padding:1.75rem 1.5rem 1.25rem;flex-shrink:0">
        <a href="/feed" style="font-family:'Playfair Display',serif;font-size:2rem;font-style:italic;font-weight:600;color:#e87aaa;text-decoration:none;display:flex;align-items:center;gap:.5rem">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#e87aaa"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            HeartMeet
        </a>
    </div>

    @if (_isAuth)
    {
        <!-- User card -->
        <div style="padding:.75rem 1.25rem 1rem;border-top:1px solid rgba(212,90,138,.08);border-bottom:1px solid rgba(212,90,138,.08);flex-shrink:0">
            <a href="/profile/@_userId" style="display:flex;align-items:center;gap:.9rem;text-decoration:none">
                @if (_avatarUrl != null)
                {
                    <img src="@_avatarUrl" style="width:52px;height:52px;border-radius:50%;object-fit:cover;border:2px solid rgba(212,90,138,.4);flex-shrink:0" />
                }
                else
                {
                    <div style="width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#9e3a62,#7c4dba);display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:700;color:#fff;flex-shrink:0;border:2px solid rgba(212,90,138,.4)">
                        @_initial
                    </div>
                }
                <div style="min-width:0">
                    <div style="font-weight:600;font-size:1rem;color:#f0e8f5;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@_name</div>
                    <div style="font-size:.78rem;color:#7a6080;margin-top:.1rem">Посмотреть профиль →</div>
                </div>
            </a>
        </div>

        <!-- Nav -->
        <nav style="flex:1;padding:1rem .75rem;display:flex;flex-direction:column;gap:.15rem;overflow-y:auto;min-height:0">

            <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;padding:.25rem .75rem .5rem;font-weight:700">Меню</div>

            <a href="/feed" class="sb-link @A("/feed")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                Анкеты
            </a>

            <a href="/chats" class="sb-link @A("/chats")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Чаты
                @if (_unreadChats > 0)
                { <span style="margin-left:auto;background:#d45a8a;color:#fff;border-radius:10px;font-size:.65rem;font-weight:700;padding:2px 7px">@_unreadChats</span> }
            </a>

            <a href="/likes" class="sb-link @A("/likes")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                Кто лайкнул
                @if (_unreadLikes > 0)
                { <span style="margin-left:auto;background:rgba(212,90,138,.25);color:#e87aaa;border-radius:10px;font-size:.65rem;font-weight:700;padding:2px 7px">@_unreadLikes</span> }
            </a>

            <div style="height:1px;background:rgba(212,90,138,.08);margin:.5rem 0"></div>
            <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;padding:.25rem .75rem .5rem;font-weight:700">Профиль</div>

            <a href="/profile/@_userId" class="sb-link @A("/profile")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Мой профиль
            </a>

            <a href="/profile/edit" class="sb-link @A("/profile/edit")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Редактировать
            </a>

            @if (_isAdmin)
            {
                <div style="height:1px;background:rgba(212,90,138,.08);margin:.5rem 0"></div>
                <a href="/admin" class="sb-link @A("/admin")">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Админ-панель
                </a>
            }

            <!-- Notifications -->
            @if (_notifs.Any())
            {
                <div style="height:1px;background:rgba(212,90,138,.08);margin:.5rem 0"></div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.25rem .75rem .4rem">
                    <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:#4a3855;font-weight:700">
                        Уведомления @(_unread > 0 ? $"({_unread})" : "")
                    </div>
                    @if (_unread > 0)
                    { <button @onclick="MarkAll" style="background:none;border:none;color:#7a6080;font-size:.7rem;cursor:pointer;padding:0">Прочитать</button> }
                </div>
                @foreach (var n in _notifs.Take(4))
                {
                    <a href="@(n.LinkUrl ?? "#")" @onclick="()=>MarkOne(n.Id)"
                       style="@($"display:flex;align-items:flex-start;gap:.6rem;padding:.55rem .75rem;border-radius:10px;text-decoration:none;transition:background .15s;background:{(n.IsRead?"transparent":"rgba(212,90,138,.06)")}")">
                        <div style="width:28px;height:28px;border-radius:50%;background:rgba(212,90,138,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.05rem">
                            @if (n.Type == NotificationType.Like)
                            { <svg width="13" height="13" viewBox="0 0 24 24" fill="#e87aaa"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> }
                            else if (n.Type == NotificationType.Match)
                            { <svg width="13" height="13" viewBox="0 0 24 24" fill="#c084fc"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> }
                            else
                            { <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> }
                        </div>
                        <div style="min-width:0">
                            <div style="font-size:.8rem;color:#c4a8d0;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">@n.Title</div>
                            <div style="font-size:.68rem;color:#4a3855;margin-top:.15rem">@n.CreatedAt.ToLocalTime().ToString("d MMM HH:mm")</div>
                        </div>
                    </a>
                }
            }
        </nav>

        <!-- Logout -->
        <div style="padding:1rem .75rem;border-top:1px solid rgba(212,90,138,.08);flex-shrink:0">
            <form action="/account/logout" method="post">
                <AntiforgeryToken />
                <button type="submit" class="sb-link" style="width:100%;border:none;background:transparent;cursor:pointer;color:#e05a6a;justify-content:flex-start">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Выйти
                </button>
            </form>
        </div>
    }
</div>

<!-- Mobile toggle -->
<button onclick="var s=document.getElementById('sidebar');s.style.transform=s.style.transform?'':'translateX(-100%)'"
        style="display:none;position:fixed;top:.9rem;left:1rem;z-index:200;background:#1a1420;border:1px solid rgba(212,90,138,.2);border-radius:8px;width:40px;height:40px;align-items:center;justify-content:center;cursor:pointer;color:#f0e8f5;font-size:1.2rem"
        id="sbBtn">☰</button>

<style>
.sb-link{display:flex;align-items:center;gap:.75rem;padding:.7rem .85rem;border-radius:12px;font-size:.95rem;color:#7a6080;text-decoration:none;transition:background .15s,color .15s;font-family:'Inter',sans-serif;font-weight:400}
.sb-link:hover{background:rgba(255,255,255,.04);color:#c4a8d0}
.sb-link.active{background:rgba(212,90,138,.14);color:#e87aaa;font-weight:500}
@@media(max-width:768px){#sidebar{transform:translateX(-100%)}#sbBtn{display:flex!important}main{margin-left:0!important}}
</style>

@code {
    bool   _isAuth, _isAdmin;
    string _userId = "", _name = "", _initial = "?";
    string? _avatarUrl;
    int    _unread, _unreadChats, _unreadLikes;
    List<Notification> _notifs = new();
    Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var user = auth.User;
        _isAuth  = user.Identity?.IsAuthenticated ?? false;
        _isAdmin = user.IsInRole("Admin");
        _userId  = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _name    = user.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "";
        _initial = _name.Length > 0 ? char.ToUpper(_name[0]).ToString() : "?";
        NotifSvc.OnChange += Refresh;
        if (_isAuth) { await Load(); _timer = new Timer(async _ => await InvokeAsync(async () => { await Load(); StateHasChanged(); }), null, 8000, 8000); }
    }

    async Task Load()
    {
        if (string.IsNullOrEmpty(_userId)) return;
        _notifs      = await NotifRepo.GetForUserAsync(_userId, 4);
        _unread      = _notifs.Count(n => !n.IsRead);
        _unreadChats = await ChatRepo.GetUnreadCountAsync(_userId);
        var likeNotifs = _notifs.Count(n => n.Type == NotificationType.Like && !n.IsRead);
        _unreadLikes = likeNotifs;
        // Load avatar
        var av = await ProfileRepo.GetAvatarAsync(_userId);
        _avatarUrl = av?.Url;
    }

    void Refresh() => InvokeAsync(async () => { await Load(); StateHasChanged(); });
    async Task MarkOne(int id) => await NotifRepo.MarkReadAsync(id);
    async Task MarkAll() { await NotifRepo.MarkAllReadAsync(_userId); await Load(); }
    string A(string path) => Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    public void Dispose() { _timer?.Dispose(); NotifSvc.OnChange -= Refresh; }
}
